#!/usr/bin/env python3

import json
import os
import subprocess
import sys
from urllib.parse import urlparse

# Check if yt-dlp is installed
def check_dependencies():
    if subprocess.run(["which", "yt-dlp"], capture_output=True).returncode != 0:
        print("yt-dlp is not installed. Please install it first.")
        exit(1)
    if subprocess.run(["which", "fzf"], capture_output=True).returncode != 0:
        print("fzf is not installed. Please install it first.")
        exit(1)

def format_duration(video):
    duration_string = video.get("duration_string")
    if duration_string:
        return duration_string

    duration = video.get("duration")
    if duration is None:
        return "?:??"

    total_seconds = int(round(float(duration)))
    minutes, seconds = divmod(total_seconds, 60)
    hours, minutes = divmod(minutes, 60)
    if hours:
        return f"{hours}:{minutes:02d}:{seconds:02d}"
    return f"{minutes}:{seconds:02d}"

# Get search results from yt-dlp in JSON format
def get_search_results(query):
    # Flat extraction keeps search-result metadata we need, but skips the
    # heavier per-entry resolution that makes plain ytsearch noticeably slower.
    cmd = ['yt-dlp', f'ytsearch5:{query}', '--flat-playlist', '--dump-json']
    print(f"Searching {query}...")
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        error_output = result.stderr.strip() or result.stdout.strip() or "Unknown yt-dlp error."
        print("Error fetching results from YouTube.", file=sys.stderr)
        print(error_output, file=sys.stderr)
        exit(1)

    lines = [line for line in result.stdout.splitlines() if line.strip()]
    if not lines:
        return []

    try:
        return [json.loads(line) for line in lines]
    except json.JSONDecodeError:
        print("yt-dlp returned malformed search results.", file=sys.stderr)
        print(result.stdout.strip(), file=sys.stderr)
        exit(1)

def is_youtube_url(value):
    parsed = urlparse(value)
    if parsed.scheme not in {"http", "https"}:
        return False

    host = parsed.netloc.lower()
    youtube_hosts = {
        "youtube.com",
        "www.youtube.com",
        "m.youtube.com",
        "youtu.be",
        "www.youtu.be",
    }
    return host in youtube_hosts

# Display options and use fzf to select
def select_video(videos):
    formatted_results = "\n".join([f"{video['title']} | {format_duration(video)}" for video in videos])
    fzf = subprocess.Popen(['fzf', '--height=10', '--border', '--ansi', '--prompt=Select a video to download: '], 
                           stdin=subprocess.PIPE, stdout=subprocess.PIPE, text=True)
    selection, _ = fzf.communicate(input=formatted_results)

    if selection:
        selected_index = [i for i, video in enumerate(videos) if video['title'] in selection][0]
        return videos[selected_index]
    return None

# Download the selected video
def download_video(video):
    print(f"Downloading from {video['webpage_url']} ...")
    subprocess.run(['yt-dlp', '-x', '--audio-format', 'mp3', video['webpage_url']])

# Main function
def main():
    check_dependencies()

    # Get search query from command line arguments
    script_name = os.path.basename(os.sys.argv[0])
    query = " ".join(os.sys.argv[1:])
    
    if not query:
        print(f"Usage: {script_name} 'song name' [artist]")
        exit(1)

    if is_youtube_url(query):
        download_video({"webpage_url": query})
        return

    # Fetch search results
    videos = get_search_results(query)

    if not videos:
        print(f"No results found for '{query}'")
        exit(1)

    # Let user select a video
    selected_video = select_video(videos)

    if selected_video:
        download_video(selected_video)
    else:
        print("No video selected.")

if __name__ == "__main__":
    main()
