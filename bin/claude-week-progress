#!/usr/bin/env python3
# Prints how far through the Claude Pro weekly usage cycle we are.
# Reset happens every Saturday at 4PM local time.
# Usage: claude-week-progress [--short]
#   Default: "42.3% of week elapsed (39h 12m until reset)"
#   --short:  "42%"

import subprocess
import sys
from datetime import datetime, timedelta
from zoneinfo import ZoneInfo

args = sys.argv[1:]
short = '--short' in args
until_pct = None
if '--until' in args:
    idx = args.index('--until')
    until_pct = float(args[idx + 1].rstrip('%'))

tz_name = subprocess.check_output(
    ['timedatectl', 'show', '-p', 'Timezone', '--value']
).decode().strip()
tz = ZoneInfo(tz_name)
now = datetime.now(tz)

# weekday(): 0=Monday, 5=Saturday, 6=Sunday
days_since_saturday = (now.weekday() - 5) % 7
last_reset = (now - timedelta(days=days_since_saturday)).replace(
    hour=16, minute=0, second=0, microsecond=0
)
if last_reset > now:
    last_reset -= timedelta(weeks=1)

next_reset = last_reset + timedelta(weeks=1)
week_secs = 7 * 24 * 3600
pct = (now - last_reset).total_seconds() / week_secs * 100

if until_pct is not None:
    target = last_reset + timedelta(seconds=until_pct / 100 * week_secs)
    if target <= now:
        print(f'Already past {until_pct:g}% (currently at {pct:.1f}%)')
    else:
        wait = target - now
        h = int(wait.total_seconds() // 3600)
        m = int((wait.total_seconds() % 3600) // 60)
        target_str = target.strftime('%-d %b %-I:%M%p').replace('AM', 'am').replace('PM', 'pm')
        print(f'{until_pct:g}% reached in {h}h {m}m (at {target_str} {tz_name})')
elif short:
    print(f'{pct:.0f}%')
else:
    time_left = next_reset - now
    h = int(time_left.total_seconds() // 3600)
    m = int((time_left.total_seconds() % 3600) // 60)
    reset_str = next_reset.strftime('%-d %b, %-I%p').replace('AM', 'am').replace('PM', 'pm')
    print(f'{pct:.1f}% of week elapsed ({h}h {m}m until reset — {reset_str} {tz_name})')
