#!/usr/bin/env python3
# Prints how far through the Claude Pro weekly usage cycle we are.
# Reset happens every Saturday at 4PM local time.
# Usage: claude-week-progress [--short]
#   Default: "42.3% of week elapsed (39h 12m until reset)"
#   --short:  "42%"

import subprocess
import sys
from datetime import datetime, timedelta
from zoneinfo import ZoneInfo

short = '--short' in sys.argv[1:]

tz_name = subprocess.check_output(
    ['timedatectl', 'show', '-p', 'Timezone', '--value']
).decode().strip()
tz = ZoneInfo(tz_name)
now = datetime.now(tz)

# weekday(): 0=Monday, 5=Saturday, 6=Sunday
days_since_saturday = (now.weekday() - 5) % 7
last_reset = (now - timedelta(days=days_since_saturday)).replace(
    hour=16, minute=0, second=0, microsecond=0
)
if last_reset > now:
    last_reset -= timedelta(weeks=1)

next_reset = last_reset + timedelta(weeks=1)
pct = (now - last_reset).total_seconds() / (7 * 24 * 3600) * 100

if short:
    print(f'{pct:.0f}%')
else:
    time_left = next_reset - now
    h = int(time_left.total_seconds() // 3600)
    m = int((time_left.total_seconds() % 3600) // 60)
    reset_str = next_reset.strftime('%-d %b, %-I%p').replace('AM', 'am').replace('PM', 'pm')
    print(f'{pct:.1f}% of week elapsed ({h}h {m}m until reset — {reset_str} {tz_name})')
