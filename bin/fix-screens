#!/usr/bin/env bash

# This is very specific to my hardware setup, exactly which physical monitors
# I have and where they are positioned.
#
# Monitors are identified by their EDID model name so that port renumbering
# (e.g. DP-2 vs DP-3) after cable swaps doesn't break anything.

# Given a monitor model name substring, prints the xrandr output name it's
# currently connected to (e.g. "DP-2"). Returns 1 if not found.
find_output_by_name() {
	local target="$1"
	xrandr --props 2>/dev/null | awk -v target="$target" '
	/^[A-Za-z].*connected/ { output=$1; in_edid=0; edid="" }
	/EDID:/ { in_edid=1; edid=""; next }
	in_edid && /^\t\t[0-9a-f]/ { gsub(/[\t ]/, ""); edid=edid $0; next }
	in_edid && !/^\t\t[0-9a-f]/ {
		in_edid=0
		# Look for monitor name descriptor (tag fc)
		for (i=1; i<=length(edid)-9; i+=2) {
			tag = substr(edid, i, 10)
			if (tag == "000000fc00") {
				hex_name = substr(edid, i+10, 26)
				name = ""
				for (j=1; j<=length(hex_name)-1; j+=2) {
					c = strtonum("0x" substr(hex_name, j, 2))
					if (c == 10 || c == 0) break
					name = name sprintf("%c", c)
				}
				if (index(name, target) > 0) {
					print output
					exit 0
				}
			}
		}
	}
	END { exit 1 }
	'
}

ULTRAWIDE=$(find_output_by_name "U3415W")
RIGHT=$(find_output_by_name "SB220Q")
LEFT=$(find_output_by_name "HP 27vx")

if [[ -z "$ULTRAWIDE" ]]; then
	echo "ERROR: Could not find DELL U3415W ultrawide" >&2
	exit 1
fi

echo "DELL U3415W (center/primary) -> $ULTRAWIDE"
[[ -n "$RIGHT" ]] && echo "SB220Q (right)               -> $RIGHT"
[[ -n "$LEFT" ]]  && echo "HP 27vx (left)               -> $LEFT"

xrandr --output "$ULTRAWIDE" --off
sleep 0.1
xrandr --output "$ULTRAWIDE" --primary --mode 3440x1440

if [[ -n "$RIGHT" ]]; then
	xrandr --output "$RIGHT" --auto
	xrandr --output "$RIGHT" --right-of "$ULTRAWIDE"
fi

if [[ -n "$LEFT" ]]; then
	xrandr --output "$LEFT" --auto
	xrandr --output "$LEFT" --left-of "$ULTRAWIDE"
fi
